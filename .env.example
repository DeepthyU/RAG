# Environment variables for the RAG application
# Ollama configuration
OLLAMA_BASE_URL=http://localhost:11434 # Base URL for the Ollama API, which is used for language model interactions
LLM_MODEL=llama3.2 # Model name for the language model
EMBED_MODEL=nomic-embed-text # Model name for the embedding model, which is used to convert text into vector representations for retrieval
# Chunk settings
CHUNK_SIZE=512 # Number of tokens per chunk. More tokens may lead to better context but can increase latency and memory usage.
CHUNK_OVERLAP=64 # Number of tokens to overlap between chunks. This helps maintain context across chunks but can also increase redundancy.
# Retrieval settings
TOP_K=5 # Number of top relevant chunks to retrieve for answering a query. Higher values may improve answer quality but can increase response time.
